# Local overrides — values here take precedence over grafana.env.
# Copy to grafana.override.env, fill in required values, then symlink into systemd dir.

# Required: change the admin password (default is "admin" which is insecure)
GF_SECURITY_ADMIN_PASSWORD=changeme

# Optional: public URL Grafana is served from (used in alert notifications, share links, etc.)
#GF_SERVER_ROOT_URL=https://grafana.example.com

# Optional: override timezone
#TZ=Europe/Berlin
